# ============================================
#  ShineTwoPlay - Environment Variables
#  Copy this file to .env and fill in values
# ============================================

# Django secret key (generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=your-secret-key-here

# Django settings module (use shinetwoplay.settings for dev, shinetwoplay.settings_prod for production)
DJANGO_SETTINGS_MODULE=shinetwoplay.settings

# Redis configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
